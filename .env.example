# Kafka / Redpanda
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
KAFKA_TOPIC_RAW=wiki.recentchange.raw
KAFKA_CONSUMER_GROUP=wiki-postgres-writer

# Wikimedia source
WIKIMEDIA_STREAM_URL=https://stream.wikimedia.org/v2/stream/recentchange
PRODUCER_CLIENT_ID=wiki-recentchange-producer
PRODUCER_LOG_EVERY=100

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=streaming
POSTGRES_USER=stream
POSTGRES_PASSWORD=stream

# Processor tuning
PROCESSOR_BATCH_SIZE=100
PROCESSOR_FLUSH_SECONDS=3

# Dashboard
DASHBOARD_REFRESH_MS=3000
